VITE_APP_TITLE= devinggo - 后端管理系统
# 端口号
VITE_PORT=5999

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# AES加密密钥，必须与后端 settings.aesKey 保持一致（16/24/32位）
VITE_APP_AES_KEY=1234567890123456
